{
  "name": "drift-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:local": "DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/drift_test DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:5432/drift_test CLIENT_PORTAL_ACCESS_CODE_HASH=995331cb475fb701a4a204142e14bcec1277027ef345f119b7cb1fd071668a20 playwright test",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:start": "docker compose -f docker-compose.postgres.yml up -d",
    "db:stop": "docker compose -f docker-compose.postgres.yml down",
    "db:migrate:local": "DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/drift_test DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:5432/drift_test prisma migrate deploy",
    "db:seed:local": "DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/drift_test DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:5432/drift_test tsx prisma/seed.ts",
    "ops:bootstrap": "npm run db:start && sleep 5 && npm run db:migrate:local && npm run db:seed:local"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@prisma/client": "7.7.0",
    "@upstash/ratelimit": "^2.0.7",
    "@upstash/redis": "^1.35.8",
    "@sentry/nextjs": "^10.48.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "csv-parse": "^6.2.1",
    "docx": "^9.6.1",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.0",
    "googleapis": "^171.4.0",
    "inngest": "^4.2.1",
    "lucide-react": "^1.7.0",
    "next": "^16.2.3",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "resend": "^6.10.0",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "stripe": "^17.7.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
